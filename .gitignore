*.swo

# OS
.DS_Store
Thumbs.db

# Dependency directories (remove the # if you use vendor)
# vendor/

# Go workspace file (remove if you want to commit it, but often ignored for local dev)
# go.work

# Go coverage and profiling
*.out
*.prof
